# ── Backend Environment Variables ─────────────────────
# Copy this to .env for local development.
# On Render, set these in the dashboard or via render.yaml.

# ── Database ──
# Render injects DATABASE_URL automatically from its managed PostgreSQL add-on.
# For local development, SQLite is fine:
DATABASE_URL=sqlite:///./catalyst.db

# ── Security ──
# Generate a strong key for production (Render auto-generates this via render.yaml):
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE-ME-in-production

# ── App settings ──
# Set to False in production — also disables /docs and /redoc swagger UI
DEBUG=True
API_TITLE=Catalyst Discovery Platform
API_VERSION=0.1.0

# ── CORS ──
# Set this to your Vercel frontend URL AFTER deploying the frontend.
# Comma-separated if you have multiple origins:
#   FRONTEND_URL=https://catalyst-m.vercel.app,https://www.mycustomdomain.com
FRONTEND_URL=https://catalyst-m.vercel.app
